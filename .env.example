# ============================================================
#  Mirshab — sozlamalar namunasi
#  Bu faylni `.env` deb nusxalang va qiymatlarni to'ldiring:
#     cp .env.example .env
# ============================================================

# --- Telegram ---
# @BotFather dan olingan token (MAJBURIY)
BOT_TOKEN=123456789:AA...

# Bot egasi (super-admin) Telegram user_id'lari, vergul bilan ajratilgan.
# O'z ID'ingizni @userinfobot dan oling.
OWNER_IDS=123456789

# --- Ma'lumotlar bazasi ---
# Dev uchun SQLite (default), prod uchun PostgreSQL:
#   DB_URL=postgresql+asyncpg://user:pass@localhost:5432/mirshab
#
# Railway/Heroku: Postgres qo'shsangiz, ular `DATABASE_URL` ni avtomatik beradi
# va bot uni o'zi o'qiydi — DB_URL ni qo'lda yozish shart emas. Sxema
# (postgres:// → postgresql+asyncpg://) va sslmode avtomatik to'g'rilanadi.
# DIQQAT: Railway'da SQLite (default) ishlatmang — har redeploy'da ma'lumot
# o'chib ketadi. Albatta Postgres ulang.
DB_URL=sqlite+aiosqlite:///mirshab.db

# --- Redis (opsional) ---
# Anti-flood counter uchun. Bo'sh qoldirilsa — xotira ichidagi fallback ishlatiladi.
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# --- Moderatsiya sozlamalari (default qiymatlar) ---
# Necha ogohlantirishdan keyin ban:
MAX_WARNINGS=3
# Anti-flood: N soniyada M+ xabar => mute
FLOOD_WINDOW_SECONDS=5
FLOOD_MAX_MESSAGES=5
# Flood uchun mute muddati (soniya)
FLOOD_MUTE_SECONDS=300
# CAPTCHA javob berish muddati (soniya)
CAPTCHA_TIMEOUT_SECONDS=60

# --- Loglash ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Faza 7: Web dashboard (opsional) ---
WEB_ENABLED=false
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Dashboard'ga kirish uchun parol (bo'sh => himoyasiz, faqat localhost'da ishlating)
WEB_SECRET=

# --- Faza 7: rasm NSFW / OCR (opsional) ---
# requirements-ml.txt o'rnatilgan bo'lsa va true bo'lsa ishlaydi:
IMAGE_NSFW_ENABLED=false
OCR_ENABLED=false

# --- AI moderatsiya (Claude) — profilga jalb qiluvchi spam-botlar ---
# Kalit https://console.anthropic.com dan olinadi. Kalit yo'q yoki o'chiq bo'lsa
# bot heuristikaga (bait_detector) fallback qiladi.
ANTHROPIC_API_KEY=
AI_MODERATION_ENABLED=false
# Model: claude-haiku-4-5 (tez/arzon, tavsiya) | claude-sonnet-4-6 (aniqroq)
AI_MODEL=claude-haiku-4-5
